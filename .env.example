# LLM 配置（OpenAI-compatible，已切换到智谱）
# 将 OPENAI_API_KEY 替换为你的智谱 API Key 或在运行时通过环境变量注入。
OPENAI_API_KEY=ZHIPU_API_KEY_PLACEHOLDER
# 智谱的 OpenAI 兼容 Base URL（如需替换为实际地址请修改）
OPENAI_BASE_URL=https://openapi.zhipu.ai/v1
# 请将 OPENAI_MODEL 替换为智谱实际的“最便宜”模型名，例如：zhipu-cheapest
OPENAI_MODEL=zhipu-cheapest

# LangSmith 配置
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=your-langsmith-key
LANGSMITH_PROJECT=afc-riskops-agent
